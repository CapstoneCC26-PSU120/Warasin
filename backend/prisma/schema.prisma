generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}

model ChatSession {
  id        String   @id @default(uuid())
  userId    String
  answers   Json?
  score     Float?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
