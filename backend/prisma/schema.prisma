generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  createdAt     DateTime      @default(now())
  birthDate     DateTime?
  avatarUrl     String?
  chatHistories ChatHistory[]

  @@map("users")
}

model ChatHistory {
  id        String   @id @default(uuid())
  userId    String
  answers   Json
  score     Float?
  category  String?
  advice    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("chat_history")
}
